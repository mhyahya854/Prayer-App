{
    "name": "prayer-app",
    "overrides": {
        "jest-util": {
            "picomatch": "2.3.2"
        },
        "micromatch": {
            "picomatch": "2.3.2"
        },
        "anymatch": {
            "picomatch": "2.3.2"
        }
    },
    "scripts": {
        "test:android": "node ./scripts/run-root-workspace-task.mjs workspace-script android test",
        "ios": "node ./scripts/run-root-workspace-task.mjs workspace-script ios ios",
        "build:core": "npm run build --workspace @prayer-app/core",
        "generate:content-seeds": "node ./scripts/generate-content-seeds.mjs",
        "android": "node ./scripts/run-root-workspace-task.mjs workspace-script android android",
        "lint:web": "npm run lint --workspace @prayer-app/web",
        "preflight": "node ./scripts/release-preflight.mjs",
        "preflight:release": "node ./scripts/release-preflight.mjs --strict-release",
        "preflight:web-release": "npm run typecheck && npm run test:core && npm run test:api && npm run test:web && npm run lint:web && npm run test:root && node ./scripts/release-preflight.mjs --web-release && npm run test:e2e:web",
        "test:core": "npm run test --workspace @prayer-app/core",
        "pack:source": "npm run preflight && node ./scripts/pack-source.mjs",
        "test:e2e:web": "playwright test",
        "test:ios": "node ./scripts/run-root-workspace-task.mjs workspace-script ios test",
        "test:root": "node --test ./scripts/*.test.mjs",
        "clean": "node ./scripts/clean-workspace.mjs",
        "verify:fresh": "npm run preflight && node ./scripts/verify-fresh.mjs",
        "api": "npm run dev --workspace @prayer-app/api",
        "test:web": "npm run test --workspace @prayer-app/web",
        "typecheck": "node ./scripts/run-root-workspace-task.mjs typecheck",
        "test:api": "npm run test --workspace @prayer-app/api",
        "web": "npm run web --workspace @prayer-app/web"
    },
    "devDependencies": {
        "@playwright/test": "^1.55.0",
        "archiver": "^7.0.1",
        "extract-zip": "^2.0.1",
        "tsx": "^4.21.0"
    },
    "workspaces": [
        "android",
        "ios",
        "web",
        "api",
        "packages/*"
    ],
    "private": true
}
