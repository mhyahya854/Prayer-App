APP_STAGE=development
PORT=4000
HOST=0.0.0.0
# Comma-separated production browser origins allowed to call web notification endpoints.
ALLOWED_ORIGINS=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/google/callback
# Required for durable web push subscriptions, installation profiles, and queued jobs.
DATABASE_URL=
# Must match EXPO_PUBLIC_WEB_PUSH_PUBLIC_KEY in the web client.
WEB_PUSH_PUBLIC_KEY=
# Required to sign outgoing browser push deliveries.
WEB_PUSH_PRIVATE_KEY=
# Production VAPID contact identity for web push delivery.
WEB_PUSH_SUBJECT=mailto:notifications@example.com
NOTIFICATION_WORKER_INTERVAL_MS=30000
