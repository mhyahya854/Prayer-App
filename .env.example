# Prayer App environment template
# Copy to .env for local development, then fill in real values.
# Do not commit populated credential files.

# Shared stage controls
# These defaults are for local development only.
# Web release preflight requires both stage values to be changed to staging or production.
APP_STAGE=development
EXPO_PUBLIC_APP_STAGE=development

# API runtime
HOST=0.0.0.0
PORT=4000
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
DATABASE_URL=postgres://postgres:postgres@localhost:5432/prayer_app
NOTIFICATION_WORKER_INTERVAL_MS=30000

# Web push (API)
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:notifications@example.com

# Google OAuth (API)
# Local callback only. Replace with the deployed API callback before any staging/production release.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/google/callback
GOOGLE_PLACES_API_KEY=

# Client runtime
# Local API only. Replace with the deployed HTTPS API origin before any staging/production release.
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_WEB_PUSH_PUBLIC_KEY=
