{
  "expo": {
    "name": "Prayer App Android",
    "slug": "prayer-app-android",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "prayerappandroid",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#10261F"
    },
    "android": {
      "package": "com.prayerapp.android",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#10261F",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Prayer App to use your location to calculate accurate prayer times for your area."
        }
      ],
      "expo-audio",
      [
        "expo-notifications",
        {
          "defaultChannel": "prayer-start",
          "sounds": [
            "./assets/sounds/athan.wav",
            "./assets/sounds/reminder.wav"
          ]
        }
      ],
      "expo-sqlite",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
